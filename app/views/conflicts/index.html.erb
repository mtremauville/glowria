<style>
  .conflicts-page {
  min-height: 100vh;
  padding: 4rem 0 6rem;
  background:
    radial-gradient(circle at top left, rgba(214, 204, 194, 0.28), transparent 35%),
    radial-gradient(circle at top right, rgba(235, 228, 219, 0.35), transparent 30%),
    #f7f3ee;
  font-family: "Inter", sans-serif;
  color: #2f261e;
}

/* =========================
   CONTAINER
========================= */

.container--xl {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* =========================
   HERO
========================= */

.conflicts-hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 2rem;
  margin-bottom: 4rem;
}

.conflicts-hero__content {
  max-width: 720px;
}

.conflicts-hero__eyebrow {
  margin: 0 0 1rem;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #8d7d6d;
}

.conflicts-hero__title {
  margin: 0;
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(3rem, 5vw, 5rem);
  line-height: 0.95;
  font-weight: 500;
  color: #2f261e;
}

.conflicts-hero__subtitle {
  margin-top: 1.4rem;
  font-size: 1.1rem;
  line-height: 1.8;
  color: #6f6459;
}

.conflicts-hero__subtitle strong {
  color: #2f261e;
  font-weight: 600;
}

/* =========================
   BUTTONS
========================= */

.conflicts-hero__actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.75rem;
  flex-shrink: 0;
}

.conflicts-back-btn,
.conflicts-primary-btn,
.conflicts-secondary-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  text-decoration: none;
  transition: all 0.25s ease;
}

.conflicts-back-btn {
  padding: 1rem 1.4rem;
  border: 1px solid rgba(47, 38, 30, 0.12);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.7);
  color: #2f261e;
  font-size: 0.95rem;
  font-weight: 500;
  backdrop-filter: blur(10px);
}

.conflicts-back-btn:hover {
  transform: translateY(-1px);
  background: white;
}

.conflicts-primary-btn {
  padding: 1rem 2rem;
  border-radius: 999px;
  background: #2f261e;
  color: white;
  font-weight: 500;
  box-shadow: 0 10px 30px rgba(47, 38, 30, 0.15);
}

.conflicts-primary-btn:hover {
  transform: translateY(-2px);
  background: #1f1813;
}

.conflicts-primary-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

.conflicts-primary-btn [data-conflict-checker-target="spinner"] {
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.conflicts-secondary-btn {
  padding: 0.95rem 1.3rem;
  border: 1px solid rgba(47, 38, 30, 0.12);
  border-radius: 999px;
  color: #2f261e;
  font-size: 0.95rem;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.7);
}

.conflicts-secondary-btn:hover {
  transform: translateY(-1px);
  background: white;
}

/* =========================
   EMPTY STATE
========================= */

.conflicts-empty-card {
  max-width: 760px;
  margin: 4rem auto 0;
  text-align: center;
  padding: 5rem 3rem;
  border-radius: 32px;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(18px);
  border: 1px solid rgba(47, 38, 30, 0.06);
  box-shadow: 0 20px 60px rgba(47, 38, 30, 0.08);
}

.conflicts-empty-card__icon {
  width: 88px;
  height: 88px;
  margin: 0 auto 2rem;
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: rgba(218, 239, 214, 0.6);
  color: #4d7d55;
  font-size: 2rem;
}

.conflicts-empty-card__title {
  margin: 0;
  font-family: "Cormorant Garamond", serif;
  font-size: 3rem;
  font-weight: 500;
}

.conflicts-empty-card__subtitle {
  max-width: 580px;
  margin: 1.2rem auto 2.5rem;
  font-size: 1.05rem;
  line-height: 1.8;
  color: #6f6459;
}

/* =========================
   SECTIONS
========================= */

.conflicts-sections {
  display: flex;
  flex-direction: column;
  gap: 4rem;
}

.conflicts-section__header {
  display: flex;
  align-items: flex-start;
  gap: 1.3rem;
  margin-bottom: 2rem;
}

.conflicts-section__icon {
  width: 52px;
  height: 52px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}

.conflicts-section__header--high .conflicts-section__icon {
  background: rgba(239, 196, 196, 0.35);
  color: #a04343;
}

.conflicts-section__header--medium .conflicts-section__icon {
  background: rgba(245, 222, 189, 0.45);
  color: #b2741a;
}

.conflicts-section__header--low .conflicts-section__icon {
  background: rgba(214, 228, 244, 0.5);
  color: #5b7895;
}

.conflicts-section__title-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.conflicts-section__title {
  margin: 0;
  font-family: "Cormorant Garamond", serif;
  font-size: 2.2rem;
  font-weight: 500;
}

.conflicts-section__subtitle {
  margin: 0.5rem 0 0;
  color: #6f6459;
  line-height: 1.7;
}

.conflicts-badge {
  padding: 0.35rem 0.85rem;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 600;
}

.conflicts-badge--high {
  background: rgba(160, 67, 67, 0.12);
  color: #a04343;
}

.conflicts-badge--medium {
  background: rgba(178, 116, 26, 0.12);
  color: #b2741a;
}

.conflicts-badge--low {
  background: rgba(91, 120, 149, 0.12);
  color: #5b7895;
}

/* =========================
   GRID
========================= */

.conflicts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
  gap: 2rem;
}

/* =========================
   CARD
========================= */

.conflict-card {
  padding: 2rem;
  border-radius: 28px;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(14px);
  border: 1px solid rgba(47, 38, 30, 0.06);
  box-shadow: 0 18px 40px rgba(47, 38, 30, 0.06);
  transition: all 0.3s ease;
}

.conflict-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 22px 50px rgba(47, 38, 30, 0.09);
}

.conflict-card--high {
  border-left: 4px solid #c97f7f;
}

.conflict-card--medium {
  border-left: 4px solid #d9aa67;
}

.conflict-card--low {
  border-left: 4px solid #8faaca;
}

.conflict-card__top {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 1rem;
  align-items: center;
  margin-bottom: 2rem;
}

.conflict-card__product {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.conflict-card__product-icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: #f8f3ee;
  color: #8d7d6d;
  flex-shrink: 0;
}

.conflict-card__product-name {
  margin: 0;
  font-weight: 600;
  font-size: 1rem;
  color: #2f261e;
}

.conflict-card__ingredient {
  display: inline-block;
  margin-top: 0.25rem;
  font-size: 0.85rem;
  color: #8d7d6d;
}

.conflict-card__cross {
  color: #b9aa9c;
  font-size: 1.2rem;
}

.conflict-card__alert {
  margin-bottom: 1.5rem;
}

.conflict-card__alert p {
  margin: 0;
  font-size: 1rem;
  line-height: 1.8;
  color: #574b40;
}

.conflict-card__tip {
  display: flex;
  align-items: flex-start;
  gap: 0.9rem;
  padding: 1.1rem 1.2rem;
  border-radius: 18px;
  background: #f9f6f2;
  color: #6f6459;
  line-height: 1.7;
}

.conflict-card__tip i {
  margin-top: 0.15rem;
  color: #b18a5b;
}

.conflict-card__footer {
  margin-top: 2rem;
}

/* =========================
   SYNERGIES
========================= */

.conflicts-section__header--synergy .conflicts-section__icon {
  background: rgba(196, 230, 207, 0.45);
  color: #3d7a52;
}

.conflicts-badge--synergy {
  background: rgba(61, 122, 82, 0.12);
  color: #3d7a52;
}

.conflict-card--synergy {
  border-left: 4px solid #6db890;
}

.conflict-card__cross--synergy {
  color: #6db890;
}

.conflict-card__tip--synergy {
  background: rgba(218, 239, 225, 0.5);
}

.conflict-card__tip--synergy i {
  color: #3d7a52;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width: 1024px) {
  .conflicts-hero {
    flex-direction: column;
    align-items: flex-start;
  }

  .conflicts-hero__actions {
    align-items: flex-start;
    flex-direction: row;
    flex-wrap: wrap;
  }

  .conflicts-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .conflicts-page {
    padding: 2.5rem 0 4rem;
  }

  .conflicts-hero {
    margin-bottom: 2.5rem;
  }

  .conflicts-hero__title {
    font-size: 2.8rem;
  }

  .conflicts-section__title {
    font-size: 1.8rem;
  }

  .conflict-card {
    padding: 1.5rem;
    border-radius: 22px;
  }

  .conflict-card__top {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .conflict-card__cross {
    display: none;
  }

  .conflicts-empty-card {
    padding: 3rem 1.5rem;
    border-radius: 24px;
  }

  .conflicts-empty-card__title {
    font-size: 2.2rem;
  }
}
  </style>
<div class="conflicts-page">

  <div class="container container--xl">

    <!-- HEADER -->
    <div class="conflicts-hero">
      <div class="conflicts-hero__content">
        <p class="conflicts-hero__eyebrow">ANALYSE D’INTERACTIONS</p>

        <h1 class="conflicts-hero__title">
          Interactions détectées
        </h1>

        <p class="conflicts-hero__subtitle">
          <strong><%= @conflict_count %></strong>
          conflit<%= "s" if @conflict_count != 1 %>
          et
          <strong><%= @synergy_count %></strong>
          synergie<%= "s" if @synergy_count != 1 %>
          détecté<%= "s" if (@conflict_count + @synergy_count) != 1 %>
          dans ta routine.
        </p>
      </div>

      <div class="conflicts-hero__actions" data-controller="conflict-checker">
        <%= link_to conflicts_path,
              class: "conflicts-primary-btn",
              data: {
                "conflict-checker-target": "btn",
                action: "click->conflict-checker#check"
              } do %>
          <i class="fa-solid fa-rotate" data-conflict-checker-target="spinner" hidden></i>
          <i class="fa-solid fa-magnifying-glass"></i>
          <span data-conflict-checker-target="label">Vérifier les interactions</span>
        <% end %>

        <%= link_to root_path, class: "conflicts-back-btn" do %>
          <i class="fa-solid fa-arrow-left"></i>
          <span>Retour au dashboard</span>
        <% end %>
      </div>
    </div>

    <% if @conflict_count == 0 && @synergy_count == 0 %>

      <!-- EMPTY STATE -->
      <section class="conflicts-empty-card">
        <div class="conflicts-empty-card__icon">
          <i class="fa-solid fa-circle-check"></i>
        </div>

        <h2 class="conflicts-empty-card__title">
          Aucun conflit détecté
        </h2>

        <p class="conflicts-empty-card__subtitle">
          Excellente nouvelle : tous tes produits sont compatibles.
          Ta routine est saine, cohérente et optimisée.
        </p>

        <%= link_to products_path, class: "conflicts-primary-btn" do %>
          Voir ma collection
        <% end %>
      </section>

    <% else %>

      <div class="conflicts-sections">

        <%# ── CONFLICTS ── %>
        <% if @conflict_count > 0 %>
          <% conflict_config = {
            "high" => {
              icon: "fa-circle-exclamation",
              label: "Conflits sérieux",
              desc: "Ces combinaisons peuvent fragiliser ta barrière cutanée."
            },
            "medium" => {
              icon: "fa-triangle-exclamation",
              label: "Interactions modérées",
              desc: "Ces associations peuvent réduire l’efficacité ou irriter."
            },
            "low" => {
              icon: "fa-circle-info",
              label: "Optimisations possibles",
              desc: "Routine globalement saine, avec quelques ajustements utiles."
            }
          } %>

          <% %w[high medium low].each do |severity| %>
            <% next unless @conflicts_by_severity[severity]&.any? %>
            <% cfg = conflict_config[severity] %>

            <section class="conflicts-section">
              <div class="conflicts-section__header conflicts-section__header--<%= severity %>">
                <div class="conflicts-section__icon">
                  <i class="fa-solid <%= cfg[:icon] %>"></i>
                </div>

                <div>
                  <div class="conflicts-section__title-row">
                    <h2 class="conflicts-section__title"><%= cfg[:label] %></h2>
                    <span class="conflicts-badge conflicts-badge--<%= severity %>">
                      <%= @conflicts_by_severity[severity].count %>
                    </span>
                  </div>
                  <p class="conflicts-section__subtitle"><%= cfg[:desc] %></p>
                </div>
              </div>

              <div class="conflicts-grid">
                <% @conflicts_by_severity[severity].each do |conflict| %>
                  <article class="conflict-card conflict-card--<%= severity %>">
                    <div class="conflict-card__top">
                      <div class="conflict-card__product">
                        <div class="conflict-card__product-icon">
                          <i class="fa-solid fa-bottle-droplet"></i>
                        </div>
                        <div>
                          <p class="conflict-card__product-name">
                            <%= conflict[:user_product_a].product.name %>
                          </p>
                          <span class="conflict-card__ingredient">
                            <%= conflict[:ingredient_a].name %>
                          </span>
                        </div>
                      </div>

                      <div class="conflict-card__cross">
                        <i class="fa-solid fa-xmark"></i>
                      </div>

                      <div class="conflict-card__product">
                        <div class="conflict-card__product-icon">
                          <i class="fa-solid fa-bottle-droplet"></i>
                        </div>
                        <div>
                          <p class="conflict-card__product-name">
                            <%= conflict[:user_product_b].product.name %>
                          </p>
                          <span class="conflict-card__ingredient">
                            <%= conflict[:ingredient_b].name %>
                          </span>
                        </div>
                      </div>
                    </div>

                    <div class="conflict-card__body">
                      <div class="conflict-card__alert">
                        <p><%= conflict[:message] %></p>
                      </div>
                      <div class="conflict-card__tip">
                        <i class="fa-solid fa-lightbulb"></i>
                        <span><%= conflict[:recommendation] %></span>
                      </div>
                    </div>

                    <div class="conflict-card__footer">
                      <% q = "#{conflict[:ingredient_a].name} + #{conflict[:ingredient_b].name} : que faire ?" %>
                      <%= link_to chat_messages_path(q: q), class: "conflicts-secondary-btn" do %>
                        <span>Demander à l’IA</span>
                        <i class="fa-solid fa-arrow-right"></i>
                      <% end %>
                    </div>
                  </article>
                <% end %>
              </div>
            </section>
          <% end %>
        <% end %>

        <%# ── SYNERGIES ── %>
        <% if @synergy_count > 0 %>
          <% synergy_config = {
            "high" => {
              icon: "fa-star",
              label: "Synergies puissantes",
              desc: "Ces associations boostent significativement l’efficacité de ta routine."
            },
            "medium" => {
              icon: "fa-circle-check",
              label: "Bonnes associations",
              desc: "Ces ingrédients se complètent bien et renforcent leurs effets."
            },
            "low" => {
              icon: "fa-thumbs-up",
              label: "Associations positives",
              desc: "Ces combinaisons sont compatibles et légèrement bénéfiques."
            }
          } %>

          <% %w[high medium low].each do |severity| %>
            <% next unless @synergies_by_severity[severity]&.any? %>
            <% cfg = synergy_config[severity] %>

            <section class="conflicts-section">
              <div class="conflicts-section__header conflicts-section__header--synergy">
                <div class="conflicts-section__icon conflicts-section__icon--synergy">
                  <i class="fa-solid <%= cfg[:icon] %>"></i>
                </div>

                <div>
                  <div class="conflicts-section__title-row">
                    <h2 class="conflicts-section__title"><%= cfg[:label] %></h2>
                    <span class="conflicts-badge conflicts-badge--synergy">
                      <%= @synergies_by_severity[severity].count %>
                    </span>
                  </div>
                  <p class="conflicts-section__subtitle"><%= cfg[:desc] %></p>
                </div>
              </div>

              <div class="conflicts-grid">
                <% @synergies_by_severity[severity].each do |synergy| %>
                  <article class="conflict-card conflict-card--synergy">
                    <div class="conflict-card__top">
                      <div class="conflict-card__product">
                        <div class="conflict-card__product-icon">
                          <i class="fa-solid fa-bottle-droplet"></i>
                        </div>
                        <div>
                          <p class="conflict-card__product-name">
                            <%= synergy[:user_product_a].product.name %>
                          </p>
                          <span class="conflict-card__ingredient">
                            <%= synergy[:ingredient_a].name %>
                          </span>
                        </div>
                      </div>

                      <div class="conflict-card__cross conflict-card__cross--synergy">
                        <i class="fa-solid fa-plus"></i>
                      </div>

                      <div class="conflict-card__product">
                        <div class="conflict-card__product-icon">
                          <i class="fa-solid fa-bottle-droplet"></i>
                        </div>
                        <div>
                          <p class="conflict-card__product-name">
                            <%= synergy[:user_product_b].product.name %>
                          </p>
                          <span class="conflict-card__ingredient">
                            <%= synergy[:ingredient_b].name %>
                          </span>
                        </div>
                      </div>
                    </div>

                    <div class="conflict-card__body">
                      <div class="conflict-card__alert">
                        <p><%= synergy[:message] %></p>
                      </div>
                      <div class="conflict-card__tip conflict-card__tip--synergy">
                        <i class="fa-solid fa-sparkles"></i>
                        <span><%= synergy[:recommendation] %></span>
                      </div>
                    </div>

                    <div class="conflict-card__footer">
                      <%= link_to chat_messages_path(
                            q: "#{synergy[:ingredient_a].name} + #{synergy[:ingredient_b].name} : comment optimiser ?"
                          ),
                          class: "conflicts-secondary-btn" do %>
                        <span>Demander à l’IA</span>
                        <i class="fa-solid fa-arrow-right"></i>
                      <% end %>
                    </div>
                  </article>
                <% end %>
              </div>
            </section>
          <% end %>
        <% end %>

      </div>

    <% end %>

  </div>
</div>
