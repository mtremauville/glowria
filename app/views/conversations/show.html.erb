<%= render "shared/chat_styles" %>

<div class="chat-page"
     data-controller="chat"
     data-chat-avatar-url-value="<%= current_user.avatar.attached? ? url_for(current_user.avatar.variant(resize_to_fill: [40, 40])) : '' %>"
     data-chat-conversation-id-value="<%= @conversation.id %>">
  <div class="chat-shell">

    <%= render "shared/chat_sidebar", current_conversation: @conversation %>

    <main class="chat-main">
      <div class="chat-panel">

        <div class="chat-header">
          <div>
            <p class="chat-header__eyebrow">GLOWRIA AI</p>
            <h2 class="chat-header__title"><%= @conversation.title %></h2>
          </div>
          <div class="chat-header__status">
            <span class="chat-status-dot"></span>
            En ligne
          </div>
        </div>

        <div class="chat-messages" data-chat-target="messages">

          <% @messages.each do |msg| %>
            <div class="chat-message <%= msg.role == 'user' ? 'chat-message--user' : 'chat-message--assistant' %>">
              <div class="chat-message__avatar">
                <% if msg.role == "user" %>
                  <% if current_user.avatar.attached? %>
                    <%= image_tag current_user.avatar.variant(resize_to_fill: [40, 40]),
                          class: "chat-avatar-img", alt: "" %>
                  <% else %>
                    <i class="fa-solid fa-user"></i>
                  <% end %>
                <% else %>
                  <i class="fa-solid fa-wand-magic-sparkles"></i>
                <% end %>
              </div>
              <div class="chat-message__bubble">
                <%= simple_format(msg.content) %>
              </div>
            </div>
          <% end %>

          <div class="chat-typing" data-chat-target="typing" hidden>
            <span></span><span></span><span></span>
          </div>
        </div>

        <form class="chat-form" data-action="submit->chat#send">
          <input type="hidden" name="conversation_id"
                 data-chat-target="conversationId"
                 value="<%= @conversation.id %>">

          <div data-chat-target="photoPreview" hidden class="chat-photo-preview">
            <img data-chat-target="photoImg" alt="" class="chat-photo-preview__img">
            <button type="button" class="chat-photo-remove"
                    data-action="click->chat#removePhoto" title="Supprimer la photo">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>

          <div data-chat-target="cameraView" hidden class="chat-camera-view">
            <video data-chat-target="video" playsinline muted autoplay class="scan-video"></video>
            <canvas data-chat-target="canvas" hidden></canvas>
            <button type="button" class="scan-capture-btn"
                    data-action="click->chat#capturePhoto">
              <i class="fa-solid fa-circle-dot"></i> Capturer
            </button>
            <button type="button" class="scan-close-btn"
                    data-action="click->chat#closeCamera">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>

          <div class="chat-form__wrapper">
            <button type="button"
                    class="chat-camera-btn"
                    data-chat-target="cameraBtn"
                    data-action="click->chat#openCamera"
                    title="Envoyer une photo">
              <i class="fa-solid fa-camera"></i>
            </button>
            <textarea data-chat-target="input"
                      data-action="keydown->chat#handleKeydown"
                      placeholder="Continue la conversation…"
                      rows="1"
                      class="chat-input"></textarea>
            <button type="submit" data-chat-target="submit" class="chat-submit">
              <i class="fa-solid fa-paper-plane"></i>
            </button>
          </div>
        </form>

      </div>
    </main>

  </div>
</div>
