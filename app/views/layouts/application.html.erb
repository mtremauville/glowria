<%# app/views/layouts/application.html.erb %>
<!DOCTYPE html>
<html>
  <head>
    <title>Glowria</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%= render "layouts/navbar" %>
    <% if notice.present? %>
      <div class="glow-toast glow-toast--success" role="alert">
        <span class="glow-toast__icon">✓</span>
        <%= notice %>
        <button type="button" class="glow-toast__close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="glow-toast glow-toast--error" role="alert">
        <span class="glow-toast__icon">⚠</span>
        <%= alert %>
        <button type="button" class="glow-toast__close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% end %>
    <% if flash[:warning].present? %>
      <div class="glow-toast glow-toast--warning" role="alert">
        <span class="glow-toast__icon">⚡</span>
        <%= flash[:warning] %>
        <button type="button" class="glow-toast__close" onclick="this.parentElement.remove()">×</button>
      </div>
    <% end %>
    <div class="glow-page">
      <%= yield %>
    </div>
  </body>
</html>
