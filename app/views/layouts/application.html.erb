<%# app/views/layouts/application.html.erb %>
<!DOCTYPE html>
<html>
  <head>
    <title>Glowria</title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#f9a8d4">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Glowria">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="manifest" href="/manifest">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>
  <body data-controller="page-loader">

    <%# ── Overlay de chargement (interactions) ── %>
    <div class="page-loader" data-page-loader-target="overlay" hidden>
      <div class="page-loader__box">
        <div class="page-loader__spinner"></div>
        <p class="page-loader__title">Analyse en cours…</p>
        <p class="page-loader__sub">Glowria vérifie les interactions entre tes ingrédients.</p>
      </div>
    </div>

    <%= render "layouts/navbar" %>
    <% if notice.present? %>
      <div class="glow-toast glow-toast--success" role="alert">
        <span class="glow-toast__icon"><i class="fa-solid fa-circle-check"></i></span>
        <%= notice %>
        <button type="button" class="glow-toast__close" onclick="this.parentElement.remove()"><i class="fa-solid fa-xmark"></i></button>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="glow-toast glow-toast--error" role="alert">
        <span class="glow-toast__icon"><i class="fa-solid fa-circle-exclamation"></i></span>
        <%= alert %>
        <button type="button" class="glow-toast__close" onclick="this.parentElement.remove()"><i class="fa-solid fa-xmark"></i></button>
      </div>
    <% end %>
    <% if flash[:warning].present? %>
      <div class="glow-toast glow-toast--warning" role="alert">
        <span class="glow-toast__icon"><i class="fa-solid fa-bolt"></i></span>
        <%= flash[:warning] %>
        <button type="button" class="glow-toast__close" onclick="this.parentElement.remove()"><i class="fa-solid fa-xmark"></i></button>
      </div>
    <% end %>
    <div class="glow-page">
      <%= yield %>
    </div>

    <%# ── Modal de confirmation global ── %>
    <dialog id="turbo-confirm-dialog" class="confirm-dialog">
      <div class="confirm-dialog__backdrop"></div>
      <div class="confirm-dialog__box">
        <div class="confirm-dialog__icon">
          <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <p class="confirm-dialog__message" id="confirm-dialog-message"></p>
        <div class="confirm-dialog__actions">
          <button class="confirm-dialog__btn confirm-dialog__btn--cancel" id="confirm-dialog-cancel">
            Annuler
          </button>
          <button class="confirm-dialog__btn confirm-dialog__btn--confirm" id="confirm-dialog-confirm">
            Confirmer
          </button>
        </div>
      </div>
    </dialog>
  </body>
</html>
