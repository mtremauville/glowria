<%# app/views/layouts/_navbar.html.erb %>
<nav class="navbar" id="main-navbar">
  <div class="navbar-inner">

    <%# ── Brand (lien vers accueil) ── %>
    <a href="<%= root_path %>" class="navbar-brand">
      <i class="fa-solid fa-leaf navbar-brand__icon"></i>
      <span class="navbar-brand__name">Glowria</span>
    </a>

    <% unless user_signed_in? %>
      <div class="navbar-actions">
        <a href="<%= new_user_session_path %>" class="btn-glow btn-glow--ghost btn-glow--sm">Se connecter</a>
        <a href="<%= new_user_registration_path %>" class="btn-glow btn-glow--primary btn-glow--sm">S'inscrire</a>
      </div>
    <% end %>

    <% if user_signed_in? %>
      <%# ── Menu desktop ── %>
      <ul class="navbar-menu" id="navbar-menu">
        <li><a href="<%= dashboard_path %>" class="navbar-link <%= 'navbar-link--active' if current_page?(dashboard_path) %>"><i class="fa-solid fa-house"></i><span>Accueil</span></a></li>
        <li><a href="<%= products_path %>" class="navbar-link <%= 'navbar-link--active' if current_page?(products_path) %>"><i class="fa-solid fa-bottle-droplet"></i><span>Produits</span></a></li>
        <li><a href="<%= conflicts_path %>" class="navbar-link <%= 'navbar-link--active' if current_page?(conflicts_path) %>" data-action="click->page-loader#show"><i class="fa-solid fa-triangle-exclamation"></i><span>Interactions</span></a></li>
        <li><a href="<%= routines_path %>" class="navbar-link <%= 'navbar-link--active' if current_page?(routines_path) %>"><i class="fa-solid fa-clipboard-list"></i><span>Routines</span></a></li>
        <li><a href="<%= chat_messages_path %>" class="navbar-link <%= 'navbar-link--active' if current_page?(chat_messages_path) %>"><i class="fa-solid fa-wand-magic-sparkles"></i><span>Assistant IA</span></a></li>
        <% if current_user.admin? %>
          <li><a href="<%= admin_root_path %>" class="navbar-link navbar-link--admin <%= 'navbar-link--active' if request.path.start_with?('/admin') %>"><i class="fa-solid fa-shield-halved"></i><span>Admin</span></a></li>
        <% end %>
      </ul>

      <%# ── Actions desktop ── %>
      <div class="navbar-actions">
        <a href="<%= new_product_path %>" class="navbar-add-btn">
          <i class="fa-solid fa-plus"></i><span>Ajouter</span>
        </a>
        <a href="<%= profile_path %>" class="navbar-profile-btn <%= 'navbar-link--active' if current_page?(profile_path) %>" title="Mon profil">
          <%= navbar_avatar_html(current_user) %>
        </a>
        <a href="<%= destroy_user_session_path %>" data-turbo-method="delete" class="navbar-signout" title="Déconnexion">
          <i class="fa-solid fa-right-from-bracket"></i>
        </a>
      </div>

      <%# ── Burger (mobile uniquement) ── %>
      <button class="navbar-burger" id="navbar-burger" aria-label="Menu" aria-expanded="false">
        <i class="fa-solid fa-bars" id="burger-icon"></i>
      </button>
    <% end %>

  </div>

  <%# ── Drawer mobile ── %>
  <% if user_signed_in? %>
    <div class="navbar-drawer" id="navbar-drawer">
      <div class="navbar-drawer__inner">
        <a href="<%= dashboard_path %>" class="drawer-link <%= 'drawer-link--active' if current_page?(dashboard_path) %>"><i class="fa-solid fa-house"></i> Accueil</a>
        <a href="<%= products_path %>" class="drawer-link <%= 'drawer-link--active' if current_page?(products_path) %>"><i class="fa-solid fa-bottle-droplet"></i> Produits</a>
        <a href="<%= conflicts_path %>" class="drawer-link <%= 'drawer-link--active' if current_page?(conflicts_path) %>" data-action="click->page-loader#show"><i class="fa-solid fa-triangle-exclamation"></i> Interactions</a>
        <a href="<%= routines_path %>" class="drawer-link <%= 'drawer-link--active' if current_page?(routines_path) %>"><i class="fa-solid fa-clipboard-list"></i> Routines</a>
        <a href="<%= chat_messages_path %>" class="drawer-link <%= 'drawer-link--active' if current_page?(chat_messages_path) %>"><i class="fa-solid fa-wand-magic-sparkles"></i> Assistant IA</a>
        <% if current_user.admin? %>
          <a href="<%= admin_root_path %>" class="drawer-link drawer-link--admin <%= 'drawer-link--active' if request.path.start_with?('/admin') %>"><i class="fa-solid fa-shield-halved"></i> Administration</a>
        <% end %>
        <div class="drawer-divider"></div>
        <a href="<%= new_product_path %>" class="drawer-link drawer-link--add">
          <i class="fa-solid fa-plus"></i> Ajouter un produit
        </a>
        <a href="<%= profile_path %>" class="drawer-link <%= 'drawer-link--active' if current_page?(profile_path) %>">
          <i class="fa-solid fa-circle-user"></i> Mon profil
        </a>
        <a href="<%= destroy_user_session_path %>" data-turbo-method="delete" class="drawer-link drawer-link--signout">
          <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
        </a>
      </div>
    </div>

    <%# Overlay pour fermer le drawer en cliquant à côté %>
    <div class="navbar-overlay" id="navbar-overlay"></div>
  <% end %>
</nav>
