<%# app/views/layouts/_navbar.html.erb %>

<%# ── Navbar desktop ── %>
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <%= link_to root_path, class: "navbar-brand" do %>
      <i class="fa-solid fa-leaf"></i> Glowria
    <% end %>

    <div class="d-flex align-items-center gap-2">
      <%= link_to root_path,          class: "nav-icon-btn #{'active' if current_page?(root_path)}",          title: "Dashboard" do %><i class="fa-solid fa-house"></i><% end %>
      <%= link_to products_path,      class: "nav-icon-btn #{'active' if current_page?(products_path)}",      title: "Mes produits" do %><i class="fa-solid fa-bottle-droplet"></i><% end %>
      <%= link_to conflicts_path,     class: "nav-icon-btn #{'active' if current_page?(conflicts_path)}",     title: "Interactions" do %><i class="fa-solid fa-triangle-exclamation"></i><% end %>
      <%= link_to routines_path,      class: "nav-icon-btn #{'active' if current_page?(routines_path)}",      title: "Routines" do %><i class="fa-solid fa-clipboard-list"></i><% end %>
      <%= link_to chat_messages_path, class: "nav-icon-btn #{'active' if current_page?(chat_messages_path)}", title: "Assistant IA" do %><i class="fa-solid fa-wand-magic-sparkles"></i><% end %>
      <%= link_to destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "nav-signout" do %>
        <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
      <% end %>
    </div>
  </div>
</nav>

<%# ── Bottom tab bar mobile ── %>
<nav class="bottom-nav" aria-label="Navigation principale">
  <%= link_to root_path, class: "bottom-nav__item #{'active' if current_page?(root_path)}" do %>
    <span class="bottom-nav__icon"><i class="fa-solid fa-house"></i></span>
    <span class="bottom-nav__label">Accueil</span>
  <% end %>

  <%= link_to products_path, class: "bottom-nav__item #{'active' if current_page?(products_path)}" do %>
    <span class="bottom-nav__icon"><i class="fa-solid fa-bottle-droplet"></i></span>
    <span class="bottom-nav__label">Produits</span>
  <% end %>

  <%= link_to conflicts_path, class: "bottom-nav__item #{'active' if current_page?(conflicts_path)}" do %>
    <span class="bottom-nav__icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
    <span class="bottom-nav__label">Conflits</span>
  <% end %>

  <%= link_to routines_path, class: "bottom-nav__item #{'active' if current_page?(routines_path)}" do %>
    <span class="bottom-nav__icon"><i class="fa-solid fa-clipboard-list"></i></span>
    <span class="bottom-nav__label">Routines</span>
  <% end %>

  <%= link_to chat_messages_path, class: "bottom-nav__item #{'active' if current_page?(chat_messages_path)}" do %>
    <span class="bottom-nav__icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
    <span class="bottom-nav__label">Chat IA</span>
  <% end %>
</nav>
