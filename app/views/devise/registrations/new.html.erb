<style>
.auth-page {
  min-height: 100vh;
  background: #F7F4EF;
  font-family: "Geologica", sans-serif;
}
.auth-layout {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  min-height: 100vh;
}
.auth-hero {
  position: relative;
  background: linear-gradient(rgba(28,25,22,0.22), rgba(28,25,22,0.48)),
    url("https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=1400&q=80");
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: center;
  padding: 4rem;
  color: white;
}
.auth-hero__content { max-width: 520px; position: relative; z-index: 2; }
.auth-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 3.5rem;
}
.auth-eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.7rem;
  font-weight: 500;
  opacity: 0.6;
  margin-bottom: 1.25rem;
}
.auth-hero__title {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(3rem, 5vw, 5rem);
  line-height: 0.95;
  font-weight: 400;
  font-style: italic;
  margin-bottom: 2rem;
}
.auth-hero__subtitle {
  font-size: 0.95rem;
  line-height: 1.8;
  opacity: 0.8;
  margin-bottom: 3rem;
  max-width: 420px;
}
.auth-benefits { display: flex; flex-direction: column; gap: 0.9rem; }
.auth-benefit {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.88rem;
  opacity: 0.85;
}
.auth-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3rem 2.5rem;
  background: #F7F4EF;
}
.auth-card { width: 100%; max-width: 420px; }
.auth-card__eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.7rem;
  font-weight: 500;
  color: #A39890;
  margin-bottom: 0.75rem;
}
.auth-card__title {
  font-family: "Cormorant Garamond", serif;
  font-size: 2.8rem;
  color: #1C1916;
  margin-bottom: 0.5rem;
  font-weight: 400;
  line-height: 1.05;
}
.auth-card__subtitle {
  color: #6B6560;
  line-height: 1.6;
  margin-bottom: 2.5rem;
  font-size: 0.9rem;
}
.auth-form { display: flex; flex-direction: column; gap: 1.25rem; }
.auth-group { display: flex; flex-direction: column; gap: 0.5rem; }
.auth-label-row { display: flex; justify-content: space-between; align-items: center; }
.auth-label {
  font-size: 0.78rem;
  font-weight: 600;
  color: #1C1916;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.auth-label__hint { font-size: 0.75rem; color: #A39890; }
.auth-input {
  width: 100%;
  border: 1px solid #DDD8CF;
  background: #FFFFFF;
  border-radius: 4px;
  padding: 0.85rem 1rem;
  font-size: 0.95rem;
  font-family: "Geologica", sans-serif;
  color: #1C1916;
  transition: border-color 0.2s ease;
}
.auth-input:focus { outline: none; border-color: #1C1916; }
.auth-button {
  margin-top: 0.75rem;
  width: 100%;
  background: #1C1916;
  color: white;
  border: none;
  border-radius: 4px;
  padding: 1rem;
  font-size: 0.9rem;
  font-family: "Geologica", sans-serif;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease;
}
.auth-button:hover { background: #0A0806; }
.auth-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 1.5rem 0 1rem;
}
.auth-divider::before, .auth-divider::after {
  content: "";
  flex: 1;
  height: 1px;
  background: #DDD8CF;
}
.auth-divider span { font-size: 0.75rem; color: #A39890; text-transform: uppercase; letter-spacing: 0.1em; }
.auth-footer { text-align: center; color: #6B6560; font-size: 0.88rem; }
.auth-footer__link {
  color: #1C1916;
  font-weight: 600;
  text-decoration: none;
  border-bottom: 1px solid #1C1916;
}
.auth-footer__link:hover { opacity: 0.7; }

.auth-google-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
  padding: 0.85rem 1rem;
  background: white;
  border: 1px solid #DDD8CF;
  border-radius: 4px;
  color: #1C1916;
  font-family: "Geologica", sans-serif;
  font-size: 0.9rem;
  font-weight: 500;
  text-decoration: none;
  cursor: pointer;
  transition: border-color 0.2s, box-shadow 0.2s;
  margin-bottom: 1.5rem;
}
.auth-google-btn:hover {
  border-color: #bcb3a8;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

@media (max-width: 900px) {
  .auth-layout { grid-template-columns: 1fr; }
  .auth-hero { min-height: 40vh; padding: 2.5rem 2rem; }
  .auth-panel { padding: 2.5rem 1.5rem; align-items: flex-start; }
  .auth-hero__title { font-size: 3rem; }
}
</style>

<div class="auth-page">
  <div class="auth-layout">

    <section class="auth-hero">
      <div class="auth-hero__content">
        <div class="auth-logo">
          <i class="fa-solid fa-leaf"></i>
          <span>Glowria</span>
        </div>
        <p class="auth-eyebrow">Skincare personnalisé</p>
        <h1 class="auth-hero__title">
          Commence ta<br>routine skincare<br>intelligente.
        </h1>
        <p class="auth-hero__subtitle">
          Crée ton compte gratuitement et laisse l'IA
          analyser tes produits pour une routine adaptée
          à ta peau, tes besoins et tes objectifs.
        </p>
        <div class="auth-benefits">
          <div class="auth-benefit">
            <i class="fa-solid fa-flask"></i>
            <span>Détection des conflits entre actifs</span>
          </div>
          <div class="auth-benefit">
            <i class="fa-solid fa-clock-rotate-left"></i>
            <span>Routine matin &amp; soir générée par IA</span>
          </div>
          <div class="auth-benefit">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
            <span>Conseils skincare en continu</span>
          </div>
        </div>
      </div>
    </section>

    <section class="auth-panel">
      <div class="auth-card">

        <p class="auth-card__eyebrow">Commencer</p>
        <h2 class="auth-card__title">Créer un compte</h2>
        <p class="auth-card__subtitle">Gratuit, rapide et sans engagement.</p>

        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>

          <div class="auth-group">
            <%= f.label :email, "Adresse e-mail", class: "auth-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  placeholder: "toi@exemple.com", class: "auth-input" %>
          </div>

          <div class="auth-group">
            <div class="auth-label-row">
              <%= f.label :password, "Mot de passe", class: "auth-label" %>
              <% if @minimum_password_length %>
                <span class="auth-label__hint"><%= @minimum_password_length %> car. min.</span>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "new-password",
                  placeholder: "••••••••", class: "auth-input" %>
          </div>

          <div class="auth-group">
            <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "auth-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  placeholder: "••••••••", class: "auth-input" %>
          </div>

          <%= f.submit "Créer mon compte", class: "auth-button" %>

        <% end %>

        <% if devise_mapping.omniauthable? && resource_class.omniauth_providers.include?(:google_oauth2) %>
          <div class="auth-divider"><span>ou</span></div>

          <%= link_to user_google_oauth2_omniauth_authorize_path,
                data: { turbo_method: :post },
                class: "auth-google-btn" do %>
            <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span>Continuer avec Google</span>
          <% end %>
        <% end %>

        <p class="auth-footer">
          Déjà un compte ?
          <%= link_to "Se connecter", new_session_path(resource_name), class: "auth-footer__link" %>
        </p>

      </div>
    </section>

  </div>
</div>
