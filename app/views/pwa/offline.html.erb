<%# app/views/pwa/offline.html.erb %>
<div class="min-h-screen flex flex-col items-center justify-center bg-pink-50 px-4 text-center">
  <div class="max-w-sm">
    <div style="font-size:4rem; margin-bottom:1.5rem; color:#9B8EC4">
      <i class="fa-solid fa-wifi"></i>
    </div>
    <h1 style="font-family:'DM Serif Display',serif; font-size:1.6rem; color:#2A2720; margin-bottom:.5rem">
      Vous êtes hors ligne
    </h1>
    <p style="color:#7A766E; margin-bottom:2rem">
      Vérifiez votre connexion internet et réessayez.
    </p>
    <button onclick="window.location.reload()"
            style="background:#7A9E87; color:#fff; padding:.75rem 1.5rem; border:none; border-radius:24px; font-size:.875rem; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:8px;">
      <i class="fa-solid fa-rotate"></i> Réessayer
    </button>
  </div>
</div>
