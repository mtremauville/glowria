<style>
/* ─── CHAT PAGE ─────────────────────────────────────────── */
.chat-page {
  background: #F7F4EF;
  font-family: "Geologica", sans-serif;
}
.chat-shell {
  display: grid;
  grid-template-columns: 300px 1fr;
  height: calc(100vh - 60px);
  overflow: hidden;
}

/* ─── SIDEBAR ────────────────────────────────────────────── */
.chat-sidebar {
  background: linear-gradient(
      rgba(45, 34, 24, 0.55),
      rgba(45, 34, 24, 0.72)
    ),
    url("https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=800&q=80");
  background-size: cover;
  background-position: center;
  color: white;
  display: flex;
  flex-direction: column;
  height: 100%;
}
.chat-sidebar__inner {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 2rem 1.5rem;
  overflow: hidden;
}
.chat-sidebar__top {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.15);
}
.chat-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 600;
  font-size: 1.1rem;
}
.chat-new-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 10px;
  color: white;
  padding: 0.65rem 1rem;
  font-size: 0.9rem;
  text-decoration: none;
  transition: background 0.2s;
}
.chat-new-btn:hover { background: rgba(255,255,255,0.25); color: white; }
.chat-sidebar__history {
  flex: 1;
  overflow-y: auto;
  padding: 1rem 0;
  min-height: 0;
}
.chat-history__label {
  text-transform: uppercase;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  opacity: 0.6;
  margin-bottom: 0.75rem;
}
.chat-history__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.chat-history__item {
  display: flex;
  align-items: center;
  border-radius: 8px;
  overflow: hidden;
  transition: background 0.15s;
}
.chat-history__item:hover { background: rgba(255,255,255,0.1); }
.chat-history__item--active { background: rgba(255,255,255,0.18); }
.chat-history__link {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 0.6rem 0.8rem;
  text-decoration: none;
  color: white;
  min-width: 0;
}
.chat-history__title {
  font-size: 0.88rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}
.chat-history__date { font-size: 0.72rem; opacity: 0.55; }
.chat-history__delete {
  flex-shrink: 0;
  background: transparent;
  border: none;
  color: rgba(255,255,255,0.4);
  cursor: pointer;
  padding: 0.6rem 0.6rem;
  font-size: 0.7rem;
  transition: color 0.15s;
  line-height: 1;
}
.chat-history__delete:hover { color: rgba(255,255,255,0.9); }
.chat-history__item form { margin: 0; }
.chat-history__empty { font-size: 0.85rem; opacity: 0.6; padding: 0.5rem 0; }
.chat-sidebar__footer {
  padding-top: 1.5rem;
  border-top: 1px solid rgba(255,255,255,0.15);
}
.chat-sidebar__eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.68rem;
  opacity: 0.6;
  margin-bottom: 0.4rem;
}
.chat-sidebar__tagline {
  font-family: "Cormorant Garamond", serif;
  font-size: 1.35rem;
  line-height: 1.3;
  font-weight: 400;
  font-style: italic;
  opacity: 0.9;
}

/* ─── MAIN ────────────────────────────────────────────────── */
.chat-main {
  display: flex;
  align-items: stretch;
  justify-content: center;
  padding: 1.25rem 1.5rem;
  height: 100%;
  overflow: hidden;
  box-sizing: border-box;
}
.chat-panel {
  width: 100%;
  max-width: 900px;
  height: 100%;
  background: rgba(255,255,255,0.82);
  backdrop-filter: blur(20px);
  border-radius: 32px;
  border: 1px solid rgba(90, 75, 60, 0.08);
  box-shadow: 0 20px 60px rgba(53, 37, 20, 0.08);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* HEADER */
.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.75rem 2.5rem;
  border-bottom: 1px solid rgba(90, 75, 60, 0.08);
}
.chat-header__eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.68rem;
  opacity: 0.6;
  margin-bottom: 0.25rem;
}
.chat-header__title {
  font-family: "Cormorant Garamond", serif;
  font-size: 2rem;
  color: #1C1916;
  font-weight: 400;
  font-style: italic;
  margin: 0;
}
.chat-header__status {
  display: flex;
  align-items: center;
  gap: 10px;
  color: #6d6258;
  font-size: 0.9rem;
}
.chat-status-dot {
  width: 9px;
  height: 9px;
  background: #8fc88a;
  border-radius: 50%;
}

/* MESSAGES */
.chat-messages {
  flex: 1;
  min-height: 0;       /* crucial : permet au flex child de réduire */
  overflow-y: auto;
  padding: 2rem 2.5rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.chat-welcome {
  max-width: 620px;
  margin: auto;
  text-align: center;
}
.chat-welcome__icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 1.75rem;
  border-radius: 50%;
  background: linear-gradient(135deg, #f4e7dc, #ede4d9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b735d;
  font-size: 1.8rem;
}
.chat-welcome__title {
  font-family: "Cormorant Garamond", serif;
  font-size: 2.4rem;
  color: #1C1916;
  margin-bottom: 0.75rem;
  font-weight: 400;
  font-style: italic;
}
.chat-welcome__subtitle {
  color: #7a6d61;
  line-height: 1.8;
  max-width: 500px;
  margin: 0 auto 2rem;
  font-size: 0.95rem;
}
.chat-suggestions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}
.chat-suggestion-btn {
  border: 1px solid #ddd4ca;
  background: rgba(255,255,255,0.9);
  border-radius: 999px;
  padding: 0.75rem 1.2rem;
  color: #3b3128;
  cursor: pointer;
  transition: all 0.25s ease;
  font-size: 0.9rem;
}
.chat-suggestion-btn:hover { transform: translateY(-2px); border-color: #bcae9e; background: white; }

/* BUBBLES */
.chat-message {
  display: flex;
  gap: 1rem;
  max-width: 78%;
}
.chat-message--user { align-self: flex-end; flex-direction: row-reverse; }
.chat-message__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #f1ebe5;
  color: #7a6d61;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.chat-message__bubble {
  padding: 1rem 1.3rem;
  border-radius: 22px;
  line-height: 1.7;
  font-size: 0.95rem;
}
.chat-message--assistant .chat-message__bubble {
  background: #f5f1ec;
  color: #1C1916;
  border-top-left-radius: 8px;
}
.chat-message--user .chat-message__bubble {
  background: #1C1916;
  color: white;
  border-top-right-radius: 8px;
}

/* TYPING (ancien indicateur flottant — masqué) */
.chat-typing { display: none; }

/* TYPING dans la bulle */
.chat-bubble-typing {
  display: flex;
  gap: 6px;
  align-items: center;
  padding: 2px 0;
}
.chat-bubble-typing span {
  width: 7px; height: 7px;
  background: #b8a999;
  border-radius: 50%;
  animation: blink 1.4s infinite;
}
.chat-bubble-typing span:nth-child(2) { animation-delay: .2s; }
.chat-bubble-typing span:nth-child(3) { animation-delay: .4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: .3; }
  40% { opacity: 1; }
}

/* INPUT */
.chat-form {
  padding: 1.5rem 2rem;
  border-top: 1px solid rgba(90, 75, 60, 0.08);
  background: rgba(255,255,255,0.7);
}
.chat-form__wrapper {
  display: flex;
  align-items: flex-end;
  gap: 0.75rem;
  background: #fcfaf8;
  border: 1px solid #ddd4ca;
  border-radius: 22px;
  padding: 0.75rem;
  width: 100%;
}
.chat-form__wrapper:focus-within {
  border-color: #8b735d;
  box-shadow: 0 0 0 4px rgba(139, 115, 93, 0.08);
}
.chat-input {
  flex: 1;
  border: none;
  background: transparent;
  resize: none;
  font-size: 0.95rem;
  line-height: 1.6;
  color: #1C1916;
  max-height: 140px;
}
.chat-input:focus { outline: none; }
.chat-submit {
  width: 48px; height: 48px;
  border: none;
  border-radius: 50%;
  background: #1C1916;
  color: white;
  cursor: pointer;
  transition: all 0.25s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.chat-submit:hover { transform: scale(1.04); background: #1e1712; }

/* CAMERA */
.chat-camera-btn {
  width: 36px; height: 36px;
  border: none;
  background: transparent;
  color: #8b735d;
  cursor: pointer;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 0.95rem;
  transition: background 0.15s;
}
.chat-camera-btn:hover { background: #f1ebe5; }
.chat-camera-btn--active { color: #1C1916; background: #f1ebe5; }

/* PHOTO PREVIEW */
.chat-photo-preview {
  position: relative;
  display: inline-flex;
  margin: 0 1rem 0.6rem;
}
.chat-photo-preview__img {
  width: 72px; height: 72px;
  border-radius: 10px;
  object-fit: cover;
  border: 2px solid #ddd4ca;
}
.chat-photo-remove {
  position: absolute;
  top: -6px; right: -6px;
  width: 20px; height: 20px;
  background: #1C1916;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 0.55rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* CAMERA VIEW */
.chat-camera-view {
  position: relative;
  width: 100%;
  aspect-ratio: 4/3;
  background: #000;
  overflow: hidden;
  border-radius: 14px;
  margin-bottom: 0.6rem;
}

/* PHOTO IN BUBBLE */
.chat-message__photo {
  display: block;
  max-width: 200px;
  border-radius: 12px;
  margin-bottom: 0.4rem;
}

/* AVATAR IMG */
.chat-avatar-img {
  width: 40px; height: 40px;
  object-fit: cover;
  border-radius: 50%;
}

/* MOBILE */
@media (max-width: 900px) {
  .chat-shell { grid-template-columns: 1fr; }
  .chat-sidebar { display: none; }
  .chat-main { padding: 0.75rem; }
  .chat-panel { border-radius: 20px; }
  .chat-header { padding: 1.25rem 1.5rem; }
  .chat-messages { padding: 1.25rem 1.5rem; }
  .chat-message { max-width: 92%; }
  .chat-form { padding: 1rem 1.25rem; }
}
</style>
