<%# app/views/landing/index.html.erb %>

<%# ══════════════════════════════════════════
    A — ATTENTION : Hero
══════════════════════════════════════════ %>
<section class="landing-hero">
  <div class="landing-hero__bg"></div>
  <div class="container landing-hero__content">

    <div class="landing-hero__eyebrow">
      <i class="fa-solid fa-leaf"></i> Skincare intelligente · 100&nbsp;% gratuit
    </div>

    <h1 class="landing-hero__title">
      Ta routine <em>sur mesure</em>,<br>enfin simple.
    </h1>

    <p class="landing-hero__sub">
      Glowria analyse ta collection de produits, détecte les interactions entre ingrédients
      et génère des routines personnalisées grâce à l'IA.
    </p>

    <div class="landing-hero__ctas">
      <%= link_to new_user_registration_path, class: "db-cta-btn" do %>
        <span class="db-cta-btn__icon">✨</span> Analyser mes produits
      <% end %>
      <%= link_to new_user_session_path, class: "btn-glow btn-glow--ghost landing-hero__login" do %>
        J'ai déjà un compte <i class="fa-solid fa-arrow-right"></i>
      <% end %>
    </div>

    <p class="landing-hero__reassurance">
      <i class="fa-solid fa-lock"></i> Sans carte bancaire &nbsp;·&nbsp;
      <i class="fa-solid fa-clock"></i> Prêt·e en 30 secondes
    </p>

  </div>
</section>

<%# ══════════════════════════════════════════
    I — INTEREST : Le problème
══════════════════════════════════════════ %>
<section class="landing-problem">
  <div class="container landing-problem__inner">

    <div class="landing-problem__text">
      <p class="landing-section__eyebrow">
        <i class="fa-solid fa-triangle-exclamation"></i> Le problème
      </p>
      <h2 class="landing-section__title">
        La plupart des routines ont un défaut caché
      </h2>
      <p class="landing-problem__body">
        Combiner des actifs skincare, c'est une science.
        Un AHA appliqué après du rétinol peut irriter la peau.
        De la Vitamine&nbsp;C mélangée au Niacinamide peut perdre en efficacité.
        Et pourtant, des milliers de personnes utilisent ces combinaisons chaque jour &mdash; sans le savoir.
      </p>
      <p class="landing-problem__body">
        Ce n'est pas une question de budget ou de marque.
        C'est une question de <strong>compatibilité</strong>.
      </p>
    </div>

    <div class="landing-problem__cards">

      <div class="landing-problem__card">
        <div class="landing-problem__card-icon landing-problem__card-icon--red">
          <i class="fa-solid fa-flask"></i>
        </div>
        <div>
          <p class="landing-problem__card-title">Ingrédients incompatibles</p>
          <p class="landing-problem__card-desc">
            Certains actifs se neutralisent ou s'irritent mutuellement quand ils sont appliqués ensemble.
          </p>
        </div>
      </div>

      <div class="landing-problem__card">
        <div class="landing-problem__card-icon landing-problem__card-icon--orange">
          <i class="fa-solid fa-clock"></i>
        </div>
        <div>
          <p class="landing-problem__card-title">Ordre d'application incorrect</p>
          <p class="landing-problem__card-desc">
            Appliquer les produits dans le mauvais ordre réduit significativement leur efficacité.
          </p>
        </div>
      </div>

      <div class="landing-problem__card">
        <div class="landing-problem__card-icon landing-problem__card-icon--blue">
          <i class="fa-solid fa-question"></i>
        </div>
        <div>
          <p class="landing-problem__card-title">Routine inadaptée à ta peau</p>
          <p class="landing-problem__card-desc">
            Sans connaître ton type de peau et tes objectifs, une routine peut aggraver les problèmes au lieu de les résoudre.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>

<%# ══════════════════════════════════════════
    D — DESIRE : La solution + fonctionnalités
══════════════════════════════════════════ %>
<section class="landing-solution">
  <div class="container">

    <div class="landing-solution__header">
      <p class="landing-section__eyebrow landing-section__eyebrow--light">
        <i class="fa-solid fa-wand-magic-sparkles"></i> La solution
      </p>
      <h2 class="landing-section__title landing-section__title--light">
        Une app qui connaît ta collection mieux que toi
      </h2>
      <p class="landing-solution__sub">
        Glowria analyse chaque ingrédient, détecte les incompatibilités et compose
        ta routine idéale &mdash; adaptée à ton type de peau et tes objectifs.
      </p>
    </div>

    <div class="landing-features">

      <div class="landing-feature">
        <div class="landing-feature__icon">
          <i class="fa-solid fa-barcode"></i>
        </div>
        <div>
          <h3 class="landing-feature__title">Scanner, photographier ou saisir</h3>
          <p class="landing-feature__desc">
            Ajoute tes produits en scannant le code-barre, en photographiant la liste INCI ou en saisissant manuellement. La composition est extraite automatiquement.
          </p>
        </div>
      </div>

      <div class="landing-feature">
        <div class="landing-feature__icon">
          <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <div>
          <h3 class="landing-feature__title">Détection des conflits d'ingrédients</h3>
          <p class="landing-feature__desc">
            Rétinol&nbsp;+ Vitamine&nbsp;C, AHA&nbsp;+ Niacinamide&hellip; Glowria identifie les combinaisons à éviter dans ta collection et t'alerte avant que tu ne les utilises ensemble.
          </p>
        </div>
      </div>

      <div class="landing-feature">
        <div class="landing-feature__icon">
          <i class="fa-solid fa-clipboard-list"></i>
        </div>
        <div>
          <h3 class="landing-feature__title">Routine générée par l'IA</h3>
          <p class="landing-feature__desc">
            En un clic, l'IA compose ta routine matin et soir en tenant compte de ton type de peau, tes objectifs et les interactions entre produits.
          </p>
        </div>
      </div>

      <div class="landing-feature">
        <div class="landing-feature__icon">
          <i class="fa-solid fa-comment-dots"></i>
        </div>
        <div>
          <h3 class="landing-feature__title">Assistant skincare en temps réel</h3>
          <p class="landing-feature__desc">
            Pose tes questions sur tes produits, tes ingrédients ou tes préoccupations. L'assistant IA connaît ta collection et te répond avec précision.
          </p>
        </div>
      </div>

    </div>

  </div>
</section>

<%# ══════════════════════════════════════════
    D — DESIRE : Comment ça marche (3 étapes)
══════════════════════════════════════════ %>
<section class="landing-steps">
  <div class="container">

    <div class="landing-steps__header">
      <p class="landing-section__eyebrow">
        <i class="fa-solid fa-list-check"></i> Comment ça marche
      </p>
      <h2 class="landing-section__title">
        3 étapes, 0 prise de tête
      </h2>
    </div>

    <div class="landing-steps__grid">

      <div class="landing-step">
        <div class="landing-step__number">01</div>
        <div class="landing-step__icon">
          <i class="fa-solid fa-camera"></i>
        </div>
        <h3 class="landing-step__title">Tu ajoutes tes produits</h3>
        <p class="landing-step__desc">
          Scanne le code-barre, prends la liste INCI en photo ou saisis manuellement. La composition est importée en quelques secondes.
        </p>
      </div>

      <div class="landing-step landing-step--connector">
        <div class="landing-step__line"></div>
      </div>

      <div class="landing-step">
        <div class="landing-step__number">02</div>
        <div class="landing-step__icon">
          <i class="fa-solid fa-magnifying-glass"></i>
        </div>
        <h3 class="landing-step__title">Glowria analyse tout</h3>
        <p class="landing-step__desc">
          L'IA passe en revue chaque ingrédient, détecte les incompatibilités et identifie les associations à éviter dans ta collection.
        </p>
      </div>

      <div class="landing-step landing-step--connector">
        <div class="landing-step__line"></div>
      </div>

      <div class="landing-step">
        <div class="landing-step__number">03</div>
        <div class="landing-step__icon">
          <i class="fa-solid fa-sparkles"></i>
        </div>
        <h3 class="landing-step__title">Tu obtiens ta routine</h3>
        <p class="landing-step__desc">
          Une routine matin et soir sur mesure, adaptée à ton type de peau et tes objectifs &mdash; sans conflit d'ingrédients, sans erreur d'ordre.
        </p>
      </div>

    </div>

  </div>
</section>

<%# ══════════════════════════════════════════
    A — ACTION : CTA final
══════════════════════════════════════════ %>
<section class="landing-cta">
  <div class="landing-cta__bg"></div>
  <div class="container landing-cta__content">

    <p class="landing-cta__eyebrow"><i class="fa-solid fa-leaf"></i> Glowria</p>

    <h2 class="landing-cta__title">
      Prêt·e à prendre soin de ta peau<br>de façon vraiment efficace&nbsp;?
    </h2>

    <p class="landing-cta__sub">
      Crée ton compte en 30 secondes, ajoute tes produits
      et laisse l'IA faire le reste.
      Gratuit, sans engagement, pour toutes les peaux.
    </p>

    <%= link_to new_user_registration_path, class: "db-cta-btn" do %>
      <span class="db-cta-btn__icon">✨</span> Créer mon compte gratuitement
    <% end %>

    <div class="landing-cta__trust">
      <span><i class="fa-solid fa-lock"></i> Aucune carte requise</span>
      <span><i class="fa-solid fa-heart"></i> Pour toutes les peaux</span>
      <span><i class="fa-solid fa-shield-halved"></i> Données privées</span>
    </div>

  </div>
</section>
