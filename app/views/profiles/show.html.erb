<%# app/views/profiles/show.html.erb %>
<div class="container" style="max-width: 640px">

  <%# ── En-tête ── %>
  <%= link_to root_path, class: "prod-back" do %>
    <i class="fa-solid fa-arrow-left"></i> Accueil
  <% end %>

  <%# ── Avatar + nom ── %>
  <div class="profile-header">
    <%# Zone avatar cliquable (label → file input) %>
    <label for="avatar-input" class="profile-avatar-label" title="Changer la photo">
      <% if current_user.avatar.attached? %>
        <%= image_tag current_user.avatar.variant(resize_to_fill: [120, 120]),
              class: "profile-avatar-img", alt: "Avatar" %>
      <% else %>
        <div class="profile-avatar">
          <%= current_user.email[0].upcase %>
        </div>
      <% end %>
      <span class="profile-avatar-overlay">
        <i class="fa-solid fa-camera"></i>
      </span>
    </label>

    <div class="profile-avatar-actions">
      <% if current_user.avatar.attached? %>
        <%= button_to avatar_profile_path,
              method: :delete,
              data: { turbo_confirm: "Supprimer ta photo de profil ?" },
              class: "profile-avatar-delete",
              title: "Supprimer la photo" do %>
          <i class="fa-solid fa-trash"></i>
        <% end %>
      <% end %>
    </div>

    <div class="profile-header__info">
      <h1 class="profile-header__name">Mon profil</h1>
      <p class="profile-header__email"><%= current_user.email %></p>
      <% if current_user.provider == "google_oauth2" && User.omniauth_providers.include?(:google_oauth2) %>
        <span class="profile-header__badge">
          <svg viewBox="0 0 24 24" width="12" height="12"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Compte Google
        </span>
      <% end %>
    </div>
  </div>

  <%# Input fichier avatar (auto-soumis dès sélection) %>
  <%= form_with model: current_user, url: profile_path, method: :patch,
        id: "avatar-form", html: { multipart: true } do |f| %>
    <%= f.file_field :avatar, id: "avatar-input", class: "sr-only",
          accept: "image/*",
          onchange: "this.form.requestSubmit()" %>
  <% end %>

  <%# ── Formulaire peau ── %>
  <%= form_with model: current_user, url: profile_path, method: :patch do |f| %>

    <%# Nom affiché %>
    <div class="add-section" style="margin-bottom: 1rem">
      <div class="add-section__header">
        <div class="add-section__label">
          <i class="fa-solid fa-signature"></i>
          Nom affiché
        </div>
      </div>
      <div class="add-section__body">
        <div class="add-form-group" style="margin: 0">
          <%= f.text_field :display_name, class: "add-form-input",
                placeholder: "ex : Sophie, @sophieskin…",
                value: current_user.display_name %>
        </div>
      </div>
    </div>

    <%# Type de peau %>
    <div class="add-section" style="margin-bottom: 1rem">
      <div class="add-section__header">
        <div class="add-section__label">
          <i class="fa-solid fa-face-smile"></i>
          Mon type de peau
        </div>
      </div>
      <div class="add-section__body">
        <div class="skin-type-grid">
          <% {
            "normal"   => ["fa-face-smile",   "Normal",   "Ni trop gras, ni trop sec"],
            "sec"      => ["fa-sun",           "Sec",      "Tiraillements, manque de confort"],
            "mixte"    => ["fa-bolt",          "Mixte",    "Zone T grasse, joues sèches"],
            "gras"     => ["fa-droplet",       "Gras",     "Brillance, pores dilatés"],
            "sensible" => ["fa-heart",         "Sensible", "Rougeurs, réactivité"],
          }.each do |value, (icon, label, desc)| %>
            <label class="skin-type-option <%= 'selected' if current_user.skin_type == value %>">
              <%= f.radio_button :skin_type, value, class: "d-none" %>
              <span class="skin-type-option__icon"><i class="fa-solid <%= icon %>"></i></span>
              <span class="skin-type-option__label"><%= label %></span>
              <span class="skin-type-option__desc"><%= desc %></span>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <%# Objectifs %>
    <div class="add-section" style="margin-bottom: 1rem">
      <div class="add-section__header">
        <div class="add-section__label">
          <i class="fa-solid fa-star"></i>
          Mes objectifs
        </div>
        <span class="text-muted" style="font-size: 0.75rem">Plusieurs choix possibles</span>
      </div>
      <div class="add-section__body">
        <div class="checkbox-grid">
          <% {
            "hydratation"  => ["fa-droplet",           "Hydratation"],
            "anti-age"     => ["fa-hourglass-half",     "Anti-âge"],
            "eclat"        => ["fa-star",               "Éclat"],
            "acne"         => ["fa-bullseye",           "Anti-acné"],
            "pores"        => ["fa-magnifying-glass",   "Pores"],
            "pigmentation" => ["fa-circle-half-stroke", "Taches"]
          }.each do |value, (icon, label)| %>
            <label class="checkbox-chip">
              <%= check_box_tag "user[skin_goals][]", value,
                    Array(current_user.skin_goals).include?(value),
                    id: "goal_#{value}" %>
              <i class="fa-solid <%= icon %>"></i> <%= label %>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <%# Préoccupations %>
    <div class="add-section" style="margin-bottom: 1.5rem">
      <div class="add-section__header">
        <div class="add-section__label">
          <i class="fa-solid fa-magnifying-glass"></i>
          Mes préoccupations
        </div>
        <span class="text-muted" style="font-size: 0.75rem">Plusieurs choix possibles</span>
      </div>
      <div class="add-section__body">
        <div class="checkbox-grid">
          <% {
            "rougeurs"      => ["fa-circle",     "Rougeurs"],
            "rides"         => ["fa-water",      "Rides"],
            "cernes"        => ["fa-eye",        "Cernes"],
            "secheresse"    => ["fa-wind",       "Sécheresse"],
            "brillance"     => ["fa-star",       "Brillance"],
            "imperfections" => ["fa-circle-dot", "Imperfections"]
          }.each do |value, (icon, label)| %>
            <label class="checkbox-chip">
              <%= check_box_tag "user[skin_concerns][]", value,
                    Array(current_user.skin_concerns).include?(value),
                    id: "concern_#{value}" %>
              <i class="fa-solid <%= icon %>"></i> <%= label %>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <button type="submit" class="add-submit-btn">
      Enregistrer les modifications
    </button>

  <% end %>

  <%# ── Compte ── %>
  <% unless current_user.provider == "google_oauth2" %>
    <div class="add-section" style="margin-top: 1.5rem">
      <div class="add-section__header">
        <div class="add-section__label">
          <i class="fa-solid fa-lock"></i>
          Compte &amp; sécurité
        </div>
      </div>
      <div class="add-section__body" style="display: flex; flex-direction: column; gap: 0.75rem">
        <%= link_to edit_user_registration_path, class: "profile-account-link" do %>
          <i class="fa-solid fa-envelope"></i>
          <span>Changer l'e-mail ou le mot de passe</span>
          <i class="fa-solid fa-chevron-right" style="margin-left: auto; font-size: 0.7rem; color: var(--text-muted)"></i>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Déconnexion ── %>
  <div style="text-align: center; margin-top: 2rem; padding-bottom: 3rem">
    <%= link_to destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "profile-signout-link" do %>
      <i class="fa-solid fa-right-from-bracket"></i>
      Se déconnecter
    <% end %>
  </div>

</div>
