<%# app/views/onboarding/show.html.erb %>
<div class="container container--sm py-8">

  <div class="onboarding-hero">
    <span class="onboarding-hero__icon">🌿</span>
    <h1 class="onboarding-hero__title">Parle-moi de ta peau</h1>
    <p class="onboarding-hero__sub">
      Ces infos permettent à l'IA de personnaliser tes routines et conseils.
    </p>
  </div>

  <%= form_with model: current_user, url: onboarding_path, method: :patch do |f| %>

    <div class="glow-card mb-4">
      <div class="glow-card__header">
        <h2 class="glow-card__title">Mon type de peau</h2>
      </div>
      <div class="glow-card__body">
        <div class="skin-type-grid">
          <% {
            "normal"   => ["😊", "Normal",   "Ni trop gras, ni trop sec"],
            "sec"      => ["🌵", "Sec",      "Tiraillements, manque de confort"],
            "mixte"    => ["⚡", "Mixte",    "Zone T grasse, joues sèches"],
            "gras"     => ["💧", "Gras",     "Brillance, pores dilatés"],
            "sensible" => ["🌸", "Sensible", "Rougeurs, réactivité"],
          }.each do |value, (icon, label, desc)| %>
            <label class="skin-type-option <%= 'selected' if current_user.skin_type == value %>">
              <%= f.radio_button :skin_type, value, class: "d-none" %>
              <span class="skin-type-option__icon"><%= icon %></span>
              <span class="skin-type-option__label"><%= label %></span>
              <span class="skin-type-option__desc"><%= desc %></span>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <div class="glow-card mb-4">
      <div class="glow-card__header">
        <h2 class="glow-card__title">Mes objectifs</h2>
        <span class="text-muted text-sm">Plusieurs choix possibles</span>
      </div>
      <div class="glow-card__body">
        <div class="checkbox-grid">
          <% {
            "hydratation"  => "💧 Hydratation",
            "anti-age"     => "⏳ Anti-âge",
            "eclat"        => "✨ Éclat",
            "acne"         => "🎯 Anti-acné",
            "pores"        => "🔬 Pores",
            "pigmentation" => "🌓 Taches"
          }.each do |value, label| %>
            <label class="checkbox-chip">
              <%= check_box_tag "user[skin_goals][]", value,
                    Array(current_user.skin_goals).include?(value),
                    id: "goal_#{value}" %>
              <%= label %>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <div class="glow-card mb-6">
      <div class="glow-card__header">
        <h2 class="glow-card__title">Mes préoccupations</h2>
        <span class="text-muted text-sm">Plusieurs choix possibles</span>
      </div>
      <div class="glow-card__body">
        <div class="checkbox-grid">
          <% {
            "rougeurs"      => "🔴 Rougeurs",
            "rides"         => "〰️ Rides",
            "cernes"        => "👁️ Cernes",
            "secheresse"    => "🌬️ Sécheresse",
            "brillance"     => "🌟 Brillance",
            "imperfections" => "⚪ Imperfections"
          }.each do |value, label| %>
            <label class="checkbox-chip">
              <%= check_box_tag "user[skin_concerns][]", value,
                    Array(current_user.skin_concerns).include?(value),
                    id: "concern_#{value}" %>
              <%= label %>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <%= f.submit "Commencer →", class: "btn-glow btn-glow--primary w-100", style: "padding: 14px; font-size: 15px" %>
  <% end %>

</div>
