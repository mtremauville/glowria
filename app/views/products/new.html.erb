<%# app/views/products/new.html.erb %>
<div class="container" style="max-width: 600px">

  <%# ── En-tête ── %>
  <%= link_to products_path, class: "prod-back" do %>
    <i class="fa-solid fa-arrow-left"></i> Ma collection
  <% end %>

  <div class="add-product-header">
    <h1 class="add-product-header__title">Ajouter un produit</h1>
    <p class="add-product-header__sub">Scanne le code-barre, la composition ou saisis manuellement.</p>
  </div>

  <%# ═══════════════════════════════════════════
      1. SCAN COMPOSITION (NOUVEAU)
  ═══════════════════════════════════════════ %>
  <div class="add-section"
       data-controller="composition-scanner"
       data-composition-scanner-scan-url-value="<%= scan_composition_products_path %>">

    <div class="add-section__header">
      <div class="add-section__label">
        <i class="fa-solid fa-camera"></i>
        Photographier la composition
      </div>
      <span class="add-section__badge add-section__badge--new">IA</span>
    </div>

    <p class="add-section__desc">
      Prends en photo la liste d'ingrédients sur l'emballage. L'IA extrait automatiquement la composition.
    </p>

    <div class="add-section__body">

      <%# Bouton principal caméra %>
      <button type="button"
              class="scan-camera-btn"
              data-action="click->composition-scanner#openCamera">
        <i class="fa-solid fa-camera"></i>
        <span>Prendre une photo</span>
      </button>

      <%# Fallback file input (utilisé si getUserMedia échoue) %>
      <input type="file"
             accept="image/*"
             data-composition-scanner-target="fileInput"
             data-action="change->composition-scanner#onFileSelected"
             class="sr-only">

      <%# Vue caméra live (getUserMedia) %>
      <div data-composition-scanner-target="cameraView" hidden class="scan-camera-view">
        <video data-composition-scanner-target="video"
               class="scan-video" playsinline muted autoplay></video>
        <canvas data-composition-scanner-target="canvas" hidden></canvas>
        <button type="button"
                class="scan-capture-btn"
                data-action="click->composition-scanner#capturePhoto">
          <i class="fa-solid fa-circle-dot"></i>
          Capturer
        </button>
        <button type="button"
                class="scan-close-btn"
                data-action="click->composition-scanner#closeCamera">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <%# Preview photo ── %>
      <div data-composition-scanner-target="preview" hidden class="scan-preview">
        <img data-composition-scanner-target="previewImg" alt="Aperçu" class="scan-preview__img">
        <button type="button"
                class="scan-analyze-btn"
                data-composition-scanner-target="analyzeBtn"
                data-action="click->composition-scanner#analyze"
                disabled>
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          Analyser la composition
        </button>
      </div>

      <%# Status message %>
      <div data-composition-scanner-target="status" hidden class="scan-status"></div>

      <%# Résultats extraits %>
      <div data-composition-scanner-target="result" hidden class="scan-result">
        <div class="scan-result__header">
          <i class="fa-solid fa-list-check"></i>
          <span data-composition-scanner-target="ingredientsCount"></span>
        </div>
        <div data-composition-scanner-target="ingredientsList" class="scan-result__list"></div>
      </div>

    </div>

    <%# Formulaire de confirmation (après scan réussi) %>
    <div data-composition-scanner-target="submitSection" hidden class="scan-confirm">
      <p class="scan-confirm__label">Complète les informations du produit :</p>

      <%= form_with url: products_path, method: :post, html: { class: "composition-form" } do |f| %>

        <div class="add-form-group">
          <%= f.label :name, "Nom du produit", class: "add-form-label" %>
          <%= f.text_field :name, name: "product[name]",
                data: { "composition-scanner-target": "nameInput" },
                placeholder: "ex : Sérum Vitamine C",
                class: "add-form-input" %>
        </div>

        <div class="add-form-group">
          <%= f.label :brand, "Marque", class: "add-form-label" %>
          <%= f.text_field :brand, name: "product[brand]",
                data: { "composition-scanner-target": "brandInput" },
                placeholder: "ex : The Ordinary",
                class: "add-form-input" %>
        </div>

        <div class="add-form-group">
          <%= f.label :category, "Catégorie", class: "add-form-label" %>
          <%= f.select :category,
                options_for_select([
                  ["Nettoyant", "nettoyant"], ["Sérum", "serum"],
                  ["Crème", "creme"], ["SPF", "spf"],
                  ["Tonique", "tonique"], ["Masque", "masque"],
                  ["Exfoliant", "exfoliant"], ["Autre", "autre"]
                ]), {}, name: "product[category]", class: "add-form-select" %>
        </div>

        <%= f.submit "Ajouter à ma collection", class: "add-submit-btn" %>

      <% end %>
    </div>

  </div>

  <%# ═══════════════════════════════════════════
      2. SCAN CODE-BARRE
  ═══════════════════════════════════════════ %>
  <details class="add-section add-section--collapsible">
    <summary class="add-section__summary">
      <div class="add-section__label">
        <i class="fa-solid fa-barcode"></i>
        Scanner le code-barre
      </div>
      <i class="fa-solid fa-chevron-down add-section__chevron"></i>
    </summary>

    <div class="add-section__body"
         data-controller="barcode-scanner"
         data-barcode-scanner-lookup-url-value="<%= lookup_products_path %>">

      <div data-barcode-scanner-target="cameraView" class="scan-camera-view" hidden>
        <video data-barcode-scanner-target="video" class="scan-video" playsinline muted autoplay></video>
        <div data-barcode-scanner-target="overlay" class="scan-overlay">
          <div class="scan-overlay__frame">
            <span></span><span></span><span></span><span></span>
          </div>
          <p class="scan-overlay__hint">Centrez le code-barre dans le cadre</p>
        </div>
      </div>

      <button type="button"
              data-barcode-scanner-target="cameraBtn"
              data-action="click->barcode-scanner#toggleCamera"
              class="scan-camera-btn">
        <i class="fa-solid fa-barcode"></i>
        <span>Scanner avec la caméra</span>
      </button>

      <div class="add-or"><span>ou</span></div>

      <div class="add-form-group">
        <label class="add-form-label">Code-barre (EAN-8 ou EAN-13)</label>
        <input type="text"
               data-barcode-scanner-target="input"
               data-action="input->barcode-scanner#lookup"
               placeholder="Ex : 3600523816071"
               inputmode="numeric"
               autocomplete="off"
               class="add-form-input">
      </div>

      <div data-barcode-scanner-target="feedback"></div>
      <div data-barcode-scanner-target="preview"></div>

      <%= form_with url: products_path, method: :post do |f| %>
        <%= hidden_field_tag :barcode, "", id: "barcode_hidden" %>
        <%= f.submit "Ajouter à ma collection",
              data: { "barcode-scanner-target": "submit" },
              disabled: true,
              class: "add-submit-btn add-submit-btn--disabled" %>
      <% end %>

    </div>
  </details>

  <%# ═══════════════════════════════════════════
      3. AJOUT MANUEL
  ═══════════════════════════════════════════ %>
  <details class="add-section add-section--collapsible">
    <summary class="add-section__summary">
      <div class="add-section__label">
        <i class="fa-solid fa-pen-to-square"></i>
        Saisir manuellement
      </div>
      <i class="fa-solid fa-chevron-down add-section__chevron"></i>
    </summary>

    <div class="add-section__body">
      <%= form_with url: products_path, method: :post do |f| %>

        <div class="add-form-group">
          <%= f.label :name, "Nom du produit", class: "add-form-label" %>
          <%= f.text_field :name, name: "product[name]", class: "add-form-input",
                placeholder: "ex : Sérum Vitamine C The Ordinary" %>
        </div>

        <div class="add-form-group">
          <%= f.label :brand, "Marque", class: "add-form-label" %>
          <%= f.text_field :brand, name: "product[brand]", class: "add-form-input",
                placeholder: "ex : The Ordinary" %>
        </div>

        <div class="add-form-group">
          <%= f.label :category, "Catégorie", class: "add-form-label" %>
          <%= f.select :category,
                options_for_select([
                  ["Nettoyant", "nettoyant"], ["Sérum", "serum"],
                  ["Crème", "creme"], ["SPF", "spf"],
                  ["Tonique", "tonique"], ["Masque", "masque"],
                  ["Exfoliant", "exfoliant"], ["Autre", "autre"]
                ]), {}, name: "product[category]", class: "add-form-select" %>
        </div>

        <%= f.submit "Ajouter", class: "add-submit-btn" %>
      <% end %>
    </div>
  </details>

</div>
