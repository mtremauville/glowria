<%# app/views/dashboard/index.html.erb %>
<div data-controller="routine-loader">

<%# ── Overlay de chargement ── %>
<div data-routine-loader-target="overlay" hidden class="routine-loader-overlay">
  <div class="routine-loader-card">
    <div class="routine-loader-logo">
      <i class="fa-solid fa-leaf"></i>
      <span>Glowria</span>
    </div>
    <div class="routine-loader-icon">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
    </div>
    <h2 class="routine-loader-title">Génération en cours</h2>
    <p class="routine-loader-subtitle">L'IA analyse ta collection et crée tes routines personnalisées</p>
    <div class="routine-loader-bar-track">
      <div class="routine-loader-bar" data-routine-loader-target="bar"></div>
    </div>
    <p class="routine-loader__msg routine-loader__msg--in" data-routine-loader-target="message">
      Analyse de ta collection…
    </p>
  </div>
</div>

<%# ══════════════════════════════════════════
    HERO
══════════════════════════════════════════ %>
<section class="db-hero">
  <div class="db-hero__bg"></div>
  <div class="db-hero__content container">
    <div class="db-hero__left">
      <p class="db-hero__eyebrow">Bonjour, <%= current_user.display_name.presence || current_user.email.split("@").first.capitalize %></p>
      <h1 class="db-hero__title">Ta peau mérite le meilleur soin.</h1>
      <div class="db-hero__meta">
        <span class="db-meta-chip db-meta-chip--skin">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M6 3v3l2 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Peau <%= current_user.skin_type&.humanize || "non renseignée" %>
        </span>
        <span class="db-meta-chip">
          <i class="fa-solid fa-bottle-droplet"></i> <%= @user_products.count %> produit<%= "s" if @user_products.count != 1 %>
        </span>
        <% high_count = @conflicts.count { |c| c[:severity] == "high" } %>
        <% if high_count > 0 %>
          <span class="db-meta-chip db-meta-chip--alert">
            <i class="fa-solid fa-triangle-exclamation"></i> <%= high_count %> conflit<%= "s" if high_count > 1 %>
          </span>
        <% end %>
      </div>
    </div>
    <div class="db-hero__actions">
      <%= link_to new_product_path, class: "db-cta-btn" do %>
        <span class="db-cta-btn__icon">＋</span>
        Ajouter un produit
      <% end %>
    </div>
  </div>

  <%# Stats strip %>
  <div class="db-stats container">
    <div class="db-stat">
      <span class="db-stat__value"><%= @user_products.count %></span>
      <span class="db-stat__label">Produits</span>
    </div>
    <div class="db-stat__divider"></div>
    <div class="db-stat">
      <span class="db-stat__value"><%= @conflicts.count %></span>
      <span class="db-stat__label">Interactions</span>
    </div>
    <div class="db-stat__divider"></div>
    <div class="db-stat">
      <% routines_count = [@morning_routine, @evening_routine].compact.count %>
      <span class="db-stat__value"><%= routines_count %>/2</span>
      <span class="db-stat__label">Routines actives</span>
    </div>
    <div class="db-stat__divider"></div>
    <div class="db-stat">
      <span class="db-stat__value"><%= current_user.chat_messages.count %></span>
      <span class="db-stat__label">Conseils IA</span>
    </div>
  </div>
</section>

<div class="container db-body">

  <%# ══════════════════════════════════════════
      ALERTES CONFLITS
  ══════════════════════════════════════════ %>
  <% high = @conflicts.select { |c| c[:severity] == "high" } %>
  <% medium = @conflicts.select { |c| c[:severity] == "medium" } %>
  <% if high.any? || medium.any? %>
    <div class="db-alerts">
      <% if high.any? %>
        <div class="db-alert db-alert--danger">
          <div class="db-alert__icon"><i class="fa-solid fa-circle-xmark"></i></div>
          <div class="db-alert__body">
            <strong><%= high.count %> conflit<%= "s" if high.count > 1 %> sérieux</strong> détecté<%= "s" if high.count > 1 %> dans ta collection
          </div>
          <%= link_to "Analyser →", conflicts_path, class: "db-alert__cta" %>
        </div>
      <% end %>
      <% if medium.any? %>
        <div class="db-alert db-alert--warning">
          <div class="db-alert__icon"><i class="fa-solid fa-bolt"></i></div>
          <div class="db-alert__body">
            <strong><%= medium.count %> interaction<%= "s" if medium.count > 1 %> modérée<%= "s" if medium.count > 1 %></strong> à surveiller
          </div>
          <%= link_to "Voir →", conflicts_path, class: "db-alert__cta" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════
      ROUTINES
  ══════════════════════════════════════════ %>
  <div class="db-section">
    <div class="db-section__header">
      <h2 class="db-section__title">Mes routines</h2>
      <%= link_to "Voir tout →", routines_path, class: "db-section__link" %>
    </div>
    <div class="db-routines">
      <% [
        { period: "morning", icon: "fa-sun",  label: "Routine matin", routine: @morning_routine, gradient: "db-routine-card--morning" },
        { period: "evening", icon: "fa-moon", label: "Routine soir",  routine: @evening_routine, gradient: "db-routine-card--evening" }
      ].each do |r| %>
        <div class="db-routine-card <%= r[:gradient] %>">
          <div class="db-routine-card__header">
            <div>
              <i class="fa-solid <%= r[:icon] %> db-routine-card__icon"></i>
              <span class="db-routine-card__label"><%= r[:label] %></span>
            </div>
            <% if r[:routine] %>
              <span class="db-routine-card__age"><%= time_ago_in_words(r[:routine].generated_at) %></span>
            <% end %>
          </div>

          <div class="db-routine-card__body">
            <% if r[:routine]&.routine_steps&.any? %>
              <% steps = r[:routine].routine_steps.includes(user_product: :product).order(:order) %>
              <% steps.first(4).each do |step| %>
                <div class="db-routine-step">
                  <span class="db-routine-step__num"><%= step.order %></span>
                  <span class="db-routine-step__name"><%= step.user_product.product.name %></span>
                </div>
              <% end %>
              <% if steps.count > 4 %>
                <p class="db-routine-card__more">+ <%= steps.count - 4 %> étape<%= "s" if steps.count - 4 > 1 %></p>
              <% end %>
            <% else %>
              <p class="db-routine-card__empty">Aucune routine générée.</p>
            <% end %>
          </div>

          <div class="db-routine-card__footer">
            <%= button_to r[:routine] ? "↻ Régénérer" : "✨ Générer",
                  generate_routine_path(r[:routine] || 0),
                  method: :post,
                  class: "db-routine-card__btn",
                  data: { "routine-loader-target": "btn", action: "submit->routine-loader#show" },
                  form: { "data-turbo" => "false",
                          "data-action" => "submit->routine-loader#show" } %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ══════════════════════════════════════════
      COLLECTION
  ══════════════════════════════════════════ %>
  <div class="db-section">
    <div class="db-section__header">
      <h2 class="db-section__title">Ma collection</h2>
      <%= link_to "Tout voir →", products_path, class: "db-section__link" %>
    </div>

    <% if @user_products.any? %>
      <div class="db-products">
        <% @user_products.first(6).each do |up| %>
          <div class="db-product-card">
            <div class="db-product-card__thumb">
              <% if up.product.image_url.present? %>
                <%= image_tag up.product.image_url, alt: up.product.name %>
              <% else %>
                <span class="db-product-card__emoji"><i class="fa-solid fa-bottle-droplet"></i></span>
              <% end %>
            </div>
            <% slot_class = { "morning" => "slot-pill--morning", "evening" => "slot-pill--evening", "both" => "slot-pill--both" }.fetch(up.usage_slot.to_s, "slot-pill--both") %>
            <% slot_icons_db = { "morning" => "fa-sun", "evening" => "fa-moon", "both" => "fa-circle-half-stroke" } %>
            <span class="slot-pill <%= slot_class %> db-product-card__slot">
              <i class="fa-solid <%= slot_icons_db.fetch(up.usage_slot.to_s, 'fa-circle-half-stroke') %>"></i>
            </span>
            <div class="db-product-card__info">
              <p class="db-product-card__name"><%= up.product.name %></p>
              <p class="db-product-card__brand"><%= up.product.brand %></p>
            </div>
          </div>
        <% end %>
        <% if @user_products.count > 6 %>
          <%= link_to products_path, class: "db-product-card db-product-card--more" do %>
            <span class="db-product-card__more-count">+<%= @user_products.count - 6 %></span>
            <span class="db-product-card__more-label">voir tout</span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="db-empty">
        <div class="db-empty__icon"><i class="fa-solid fa-bottle-droplet"></i></div>
        <p class="db-empty__title">Ta collection est vide</p>
        <p class="db-empty__sub">Commence par ajouter tes premiers produits.</p>
        <%= link_to "＋ Ajouter un produit", new_product_path, class: "db-cta-btn db-cta-btn--sm" %>
      </div>
    <% end %>
  </div>

  <%# ══════════════════════════════════════════
      CHAT IA
  ══════════════════════════════════════════ %>
  <div class="db-ai-banner">
    <div class="db-ai-banner__bg"></div>
    <div class="db-ai-banner__content">
      <div>
        <p class="db-ai-banner__label">Assistant IA Glowria</p>
        <p class="db-ai-banner__title">Des conseils skincare<br>sur mesure, en temps réel.</p>
        <p class="db-ai-banner__preview">
          <% if @recent_messages.any? %>
            "<%= truncate(@recent_messages.first.content, length: 80) %>"
          <% else %>
            Pose une question sur tes produits, tes ingrédients ou tes interactions.
          <% end %>
        </p>
      </div>
      <%= link_to chat_messages_path, class: "db-ai-banner__btn" do %>
        Ouvrir le chat <span>→</span>
      <% end %>
    </div>
  </div>

</div><%# /db-body %>

</div><%# /routine-loader %>
