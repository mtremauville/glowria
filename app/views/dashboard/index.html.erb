<%# app/views/dashboard/index.html.erb %>
<div class="container" style="max-width: 860px">

  <%# ── Hero ── %>
  <div class="dash-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
      <div>
        <p class="dash-hero__greeting">
          Bonjour, <%= current_user.email.split("@").first.capitalize %> ✨
        </p>
        <p class="dash-hero__sub">
          Voici un aperçu de ta routine beauté du jour.
        </p>
        <div class="dash-hero__badge">
          🌿 Peau <%= current_user.skin_type&.humanize || "non renseignée" %> &nbsp;·&nbsp;
          <%= @user_products.count %> produit<%= "s" if @user_products.count != 1 %>
        </div>
      </div>
      <%= link_to "＋ Ajouter un produit", new_product_path, class: "btn-glow btn-glow--primary btn-glow--sm align-self-start" %>
    </div>
  </div>

  <%# ── Alertes conflits ── %>
  <% if @conflicts.any? %>
    <div class="mb-4">
      <% high = @conflicts.select { |c| c[:severity] == "high" } %>
      <% if high.any? %>
        <div class="glow-alert glow-alert--danger">
          <span class="glow-alert__icon">🔴</span>
          <div>
            <strong><%= high.count %> conflit<%= "s" if high.count > 1 %> sérieux</strong>
            dans ta collection.
            <%= link_to "Voir l'analyse →", conflicts_path, class: "glow-alert__link ms-1" %>
          </div>
        </div>
      <% end %>
      <% medium = @conflicts.select { |c| c[:severity] == "medium" } %>
      <% if medium.any? %>
        <div class="glow-alert glow-alert--warning">
          <span class="glow-alert__icon">⚡</span>
          <div>
            <strong><%= medium.count %> interaction<%= "s" if medium.count > 1 %> modérée<%= "s" if medium.count > 1 %></strong>
            à surveiller.
            <%= link_to "Voir l'analyse →", conflicts_path, class: "glow-alert__link ms-1" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Routines ── %>
  <div class="grid grid-2-auto mb-4">
    <% { "morning" => ["☀️", "Routine matin", @morning_routine], "evening" => ["🌙", "Routine soir", @evening_routine] }.each do |period, (icon, label, routine)| %>
      <div>
        <div class="routine-card">
          <div class="routine-card__header">
            <span class="routine-card__label"><%= icon %> <%= label %></span>
            <% if routine %>
              <span class="routine-card__age"><%= time_ago_in_words(routine.generated_at) %></span>
            <% end %>
          </div>
          <div class="routine-card__body">
            <% if routine&.routine_steps&.any? %>
              <ol class="routine-steps">
                <% routine.routine_steps.includes(user_product: :product).order(:order).each do |step| %>
                  <li class="routine-step">
                    <span class="routine-step__num"><%= step.order %></span>
                    <div class="routine-step__content">
                      <div class="routine-step__name"><%= step.user_product.product.name %></div>
                      <div class="routine-step__tip"><%= step.instruction %></div>
                    </div>
                  </li>
                <% end %>
              </ol>
              <% if routine.ai_summary.present? %>
                <div class="routine-summary">
                  <span>💡</span>
                  <span><%= routine.ai_summary %></span>
                </div>
              <% end %>
            <% else %>
              <p class="text-muted" style="font-size:13px; margin-bottom: 16px">
                Aucune routine générée pour le moment.
              </p>
            <% end %>
            <%= button_to "✨ Générer",
                  generate_routine_path(routine || 0),
                  method: :post,
                  class: "btn-glow btn-glow--outline btn-glow--sm w-100 mt-2",
                  form: { "data-turbo" => "false" } %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Collection ── %>
  <div class="glow-card mb-4">
    <div class="glow-card__header">
      <h2 class="glow-card__title">🧴 Ma collection</h2>
      <%= link_to "Tout voir →", products_path, class: "btn-glow btn-glow--ghost btn-glow--sm" %>
    </div>

    <% if @user_products.any? %>
      <div class="product-grid">
        <% @user_products.first(6).each do |up| %>
          <div class="product-chip">
            <% if up.product.image_url.present? %>
              <%= image_tag up.product.image_url, alt: up.product.name, class: "product-chip__img" %>
            <% else %>
              <div class="product-chip__placeholder">🧴</div>
            <% end %>
            <div class="product-chip__info">
              <span class="product-chip__name"><%= up.product.name %></span>
              <span class="product-chip__brand"><%= up.product.brand %></span>
            </div>
            <% slot_class = { "morning" => "slot-pill--morning", "evening" => "slot-pill--evening", "both" => "slot-pill--both" }.fetch(up.usage_slot, "slot-pill--both") %>
            <span class="slot-pill <%= slot_class %>">
              <%= { "morning" => "☀️ Matin", "evening" => "🌙 Soir", "both" => "✦ AM/PM" }[up.usage_slot] %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <span class="empty-state__icon">🧴</span>
        <p class="empty-state__title">Ta collection est vide</p>
        <p class="empty-state__sub">Ajoute tes premiers produits pour commencer.</p>
        <%= link_to "Ajouter un produit", new_product_path, class: "btn-glow btn-glow--primary btn-glow--sm" %>
      </div>
    <% end %>
  </div>

  <%# ── Chat shortcut ── %>
  <div class="chat-shortcut">
    <div>
      <p class="chat-shortcut__title">✨ Ton assistante skincare IA</p>
      <p class="chat-shortcut__preview">
        <% if @recent_messages.any? %>
          "<%= truncate(@recent_messages.first.content, length: 70) %>"
        <% else %>
          Pose une question sur tes produits, tes routines ou les interactions.
        <% end %>
      </p>
    </div>
    <%= link_to "Ouvrir le chat →", chat_messages_path, class: "btn-glow btn-glow--outline btn-glow--sm" %>
  </div>

</div>
